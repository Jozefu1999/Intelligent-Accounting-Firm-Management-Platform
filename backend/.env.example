# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=plateforme_comptable
DB_USER=root
DB_PASSWORD=
DB_SYNC_ALTER=false

# JWT
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRES_IN=24h

# AI provider (optional): auto, gemini, xai, or grok
AI_PROVIDER=auto

# Gemini (recommended for low-cost usage)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.0-flash-lite
AI_MAX_OUTPUT_TOKENS=650

# xAI / Grok (optional)
XAI_API_KEY=your_xai_api_key_here
# Optional aliases accepted by backend (keep empty if XAI_API_KEY is set)
GROK_API_KEY=
GROQ_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4

# Backward compatibility (optional)
OPENAI_API_KEY=
